# HoneyJar configuration
# Copy to .env and edit.

# Comma-separated list of TCP ports to listen on.
# On a real VPS, use the real low ports (22, 23, 80, 445).
# For local testing without root, use high ports.
HONEYJAR_PORTS=2222,2323,8080,4445

# Discord (or Slack) incoming webhook URL. Leave blank to log only.
HONEYJAR_WEBHOOK_URL=

# Friendly hostname for the events.
HONEYJAR_HOSTNAME=honeyjar-dev

# Local log file path.
HONEYJAR_LOG_FILE=honeyjar.log
